-- From the String Functions / Subqueries script:
--------------------------------------------------------------------------------------------------------------------------------------------
1.Write a subquery to find employees who earn less than the average salary of the company.
  select emp_name,salary
from employee
where salary < (select avg(salary)from employee);
--------------------------------------------------------------------------------------------------------------------------------------------
2.Write a correlated subquery to find the highest-paid employee in each department.
  select emp_name,salary,dept_name
FROM employee e
where salary  = (select max(salary)from employee where dept_name = e.dept_name);

--------------------------------------------------------------------------------------------------------------------------------------------
3.Using CONCAT() and UPPER(), produce a column showing each employees name in all caps followed by their department in brackets— e.g. MOHAN  (Admin).

  select emp_name,dept_name,
concat(upper(emp_name),'(',dept_name,')') as name_dept
from employee;
--------------------------------------------------------------------------------------------------------------------------------------------
4.Use CHARINDEX() to find employees whose name contains the letter 'e'.
   SELECT emp_name
FROM employee
WHERE CHARINDEX('e', emp_name) > 0;
--------------------------------------------------------------------------------------------------------------------------------------------
5.Write a stored procedure GetEmployeesAboveSalary that takes a @MinSalary INT parameter and returns all employees earning more than that amount.
  create procedure GetEmployeesAboveSalary
    @MINSalary INT
AS
BEGIN
    SELECT EMP_NAME,SALARY
    FROM EMPLOYEE
    WHERE SALARY > @MINSalary;
END;

EXEC GetEmployeesAboveSalary @MINSalary = 2000;


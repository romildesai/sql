--------------------------------------------------------------------------------------------------------------------------------------------
1.Write a query to show, for each employee, the minimum salary in their department alongside their own row.
  select e. * ,min(salary) over(partition by dept_name) as min_salary
from employee e;
--------------------------------------------------------------------------------------------------------------------------------------------
2.Using ROW_NUMBER(), fetch the last employee to join each department.(doubt)
  select * from(select emp_name,dept_name,
row_number()over(partition by dept_name order by emp_id)as row_N
from employee) x where x.row_N >2;
--------------------------------------------------------------------------------------------------------------------------------------------
3.Write a query using DENSE_RANK() to fetch employees with the top 2 distinct salary levels in each department.
  SELECT *
FROM(
    SELECT distinct E.*, 
    DENSE_RANK() OVER(PARTITION BY DEPT_NAME ORDER BY SALARY DESC) AS DENSE_RNK
    FROM EMPLOYEE E ) X
    WHERE X.DENSE_RNK <=2;
--------------------------------------------------------------------------------------------------------------------------------------------
4.Using LEAD(), write a query that shows whether each employees salary is higher, lower, or the same as the next employee in their department.
  SELECT E.*, 
lag(salary) OVER(PARTITION BY DEPT_NAME ORDER BY emp_id) AS prev_emp_salary,
CASE WHEN E.SALARY > lag(salary) OVER(PARTITION BY DEPT_NAME ORDER BY emp_id) THEN 'Higher than previous employee'
     WHEN E.SALARY < lag(salary) OVER(PARTITION BY DEPT_NAME ORDER BY emp_id) THEN 'Lower than previous employee'
     WHEN E.SALARY = lag(salary) OVER(PARTITION BY DEPT_NAME ORDER BY emp_id) THEN 'Same as previous employee'
     END SAL_RANGE
FROM EMPLOYEE E;
--------------------------------------------------------------------------------------------------------------------------------------------
5.Combine PARTITION BY dept_name with COUNT(*) OVER(PARTITION BY dept_name) to show, on every row, how many employees are in that employees department.
  select count(emp_id)over(partition by dept_name) as total_emp from employee;

